# Server Configuration
PORT=3000
NODE_ENV=production

# API Key for protected endpoints
API_KEY=your_secure_api_key_here

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=btcs_notifications
DB_USER=btcs_backend
DB_PASSWORD=CHANGE_THIS_PASSWORD

# Bitcoin Silver RPC
BITCOIN_RPC_HOST=127.0.0.1
BITCOIN_RPC_PORT=8332
BITCOIN_RPC_USER=your_rpc_username
BITCOIN_RPC_PASSWORD=your_rpc_password

# ZMQ Configuration
ZMQ_RAWTX=tcp://127.0.0.1:28332

# Firebase Cloud Messaging (use firebase-admin-key.json instead)
# FIREBASE_SERVER_KEY is deprecated, SDK uses service account file

# LiveCoinWatch API (for price monitoring)
LIVECOINWATCH_API_KEY=your_livecoinwatch_api_key

# Logging
LOG_LEVEL=info
